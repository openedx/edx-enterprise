# Environment variables for keycloak-config-cli when targetting the stage LMS
# (courses.stage.edx.org) instead of devstack.  Used by `make dev.provision.keycloak-stage`.
#
# Only the SP-side values (SP_ENTITY_ID, ACS_URL) differ from keycloak-devstack.env.
# The Keycloak side still runs locally on your laptop at edx.devstack.keycloak:8080.
#
# See docs/saml_testing_stage.rst for the manual stage-admin steps that
# accompany this provisioning.

# Keycloak realm name.  Named for parity with the local-stage Keycloak
# container so IdP entity IDs and metadata URLs make the variant obvious.
REALM_NAME=local-stage

# Keycloak base URL (Docker hostname, reachable from your host via /etc/hosts).
KEYCLOAK_URL=http://edx.devstack.keycloak:8080

# SAMLProviderConfig slug used in stage admin.  The provider_id registered with
# python-social-auth will be "saml-{SAML_SLUG}" (e.g. "saml-keycloak-stage").
SAML_SLUG=keycloak-stage

# Stage LMS Service Provider entity ID.  Must match SAMLConfiguration.entity_id
# on stage AND the Client ID of the SAML client in Keycloak.
SP_ENTITY_ID=https://courses.stage.edx.org

# Stage SAML Assertion Consumer Service URL — the stage LMS endpoint that
# receives the SAML response POST from Keycloak after the user authenticates.
ACS_URL=https://courses.stage.edx.org/auth/complete/tpa-saml/

# Standard OIDs for SAML assertion attributes.  The SAMLProviderConfig in stage
# admin must reference the same OIDs so the pipeline can extract user details
# from the assertion.
#   OID_EMAIL:      RFC 2798 mail
#   OID_GIVEN_NAME: X.520 givenName
#   OID_SURNAME:    X.520 sn (surname)
OID_EMAIL=urn:oid:0.9.2342.19200300.100.1.3
OID_GIVEN_NAME=urn:oid:2.5.4.42
OID_SURNAME=urn:oid:2.5.4.4

# Keycloak test user credentials.  A user with these attributes is created in
# the Keycloak realm for SAML login testing.  An LMS user with email TEST_EMAIL
# must already exist on stage and be linked to an EnterpriseCustomer that has
# an EnterpriseCustomerIdentityProvider row pointing at saml-{SAML_SLUG}.
TEST_USERNAME=keycloak_learner
TEST_EMAIL=keycloak_learner@example.com
TEST_PASSWORD=testpass
TEST_FIRST_NAME=Keycloak
TEST_LAST_NAME=Learner

# LMS_USERNAME / LMS_PASSWORD from keycloak-devstack.env are intentionally
# omitted here — provision-tpa.py does not run against stage, so the stage
# learner account must be created manually via stage admin.
